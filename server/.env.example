# --- CONFIGURAÇÕES DE BANCO DE DATAS (POSTGRES) ---
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=sua_senha_segura_aqui
POSTGRES_DB=finance_app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- INTELIGÊNCIA ARTIFICIAL (GOOGLE GEMINI) ---
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# --- SEGURANÇA E AUTENTICAÇÃO ---
# Chave para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=sua_chave_secreta_jwt_aqui

# --- USUÁRIOS PADRÃO DO SISTEMA ---
# Estes usuários serão criados/sincronizados automaticamente no primeiro boot
APP_USER=nome.usuario1
APP_PASS=senha_usuario1

# --- CONFIGURAÇÕES DE FRONTEND (VITE) ---
# Em produção, geralmente é /api se usar proxy do Nginx
VITE_API_URL=/api
